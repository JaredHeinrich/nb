#compdef nb

NB_ROOT_DIR="$HOME/.nb"
NOTEBOOK_DIR_NAME="notebooks"
ARCHIVE_DIR_NAME="archive"

_nb() {
  typeset -A opt_args
  local context state line
  local curcontext="$curcontext"
  local ret=1

  _arguments -C -A "-*" \
    '(- *)--version[Print version]' \
    '(- *)'{-h,--help}'[Print help]' \
    '1: :_nb_subcommands' \
    '*::arg:->args' \
    && ret=0

  case "$state" in
    (args)
      case $words[1] in
        (new)
          _arguments \
            ':name -- Name of the notebook to be created.:' \
            && ret=0
          ;;
        (open)
          _arguments \
            '::name -- Name of the notebook to open.:_notebooks' \
            && ret=0
          ;;
        (remove)
          _arguments \
            ':name -- Name of the notebook to be deleted.:_notebooks' \
            && ret=0
          ;;
        (rm)
          _arguments \
            ':name -- Name of the notebook to be deleted.:_notebooks' \
            && ret=0
          ;;
        (list)
          ret=0
          ;;
        (ls)
          ret=0
          ;;
        (completions)
          _arguments \
            '--shell+[Shell for which to return the completion script]:SHELL:(zsh)' \
            && ret=0
          ;;
        (config)
          _nb_config && ret=0
          ;;
        (archive)
          _nb_archive && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

(( $+functions[_nb_subcommands] )) ||
  _nb_subcommands() {
    local -a commands=(
      "new:Create a new notebook"
      "open:Open a notebook"
      "remove:Delete a notebook"
      "list:List existing notebooks"
      "config:Access config via cli"
      "completions:Completion script for specific shell"
      "archive:View and manage archive"
    )
    _describe -t commands 'nb commands' commands "$@"
  }

(( $+functions[_nb_config_subcommands] )) ||
  _nb_config_subcommands() {
    local -a commands=(
      "generate:Generate a default config file"
      "get:Get specific config values"
      "list:List all config values"
    )
    _describe -t commands 'command' commands "$@"
  }

(( $+functions[_nb_config] )) ||
  _nb_config() {
    local ret=1
    _arguments -C \
      '1: :_nb_config_subcommands' \
      '*:: :->arg' \
      && ret=0
    case $state in
      (arg)
        case $words[1] in
          (generate)
            _arguments \
              '(-f --force)'{-f,--force}'[Overwrite the config file if one already exists]' \
              && ret=0
            ;;
          (get)
            _arguments \
              '*::value_name:(default_notebook editor)' \
              && ret=0
            ;;
          (list)
            ret=0
            ;;
        esac
        ;;
    esac
    return $ret
  }

(( $+functions[_nb_archive_subcommands] )) ||
  _nb_archive_subcommands() {
    local -a commands=(
      "save:Archive a specific notebook"
      "list:List all archived notebooks"
      "open:Open a archived notebook"
      "restore:Restore a notebook from the archive"
      "remove:Delete a archived notebook permanently"
    )
    _describe -t commands 'command' commands "$@"
  }

(( $+functions[_nb_archive] )) ||
  _nb_archive() {
    local ret=1
    _arguments -C \
      '1: :_nb_archive_subcommands' \
      '*:: :->arg' \
      && ret=0
    case $state in
      (arg)
        case $words[1] in
          (save)
            _arguments \
              ':name -- Name of the notebook to archive:_notebooks' \
              && ret=0
            ;;
          (list)
            ret=0
            ;;
          (open)
            _arguments \
              ':name -- Name of the notebook to open:_archived_notebooks' \
              && ret=0
            ;;
          (restore)
            _arguments \
              ':archive_name -- Name of the notebook to restore from archive:_archived_notebooks' \
              '--new-name+[New name of the notebook after its restored]:NEW_NAME:' \
              && ret=0
            ;;
          (remove)
            _arguments \
              ':name -- Name of the notebook to delete from archive:_archived_notebooks' \
              && ret=0
            ;;
        esac
        ;;
    esac
    return $ret
  }

(( $+functions[_notebooks] )) ||
  _notebooks() {
    [[ -d "$NB_ROOT_DIR/$NOTEBOOK_DIR_NAME" ]] || return 1

    local -a file_paths
    file_paths=("$NB_ROOT_DIR/$NOTEBOOK_DIR_NAME"/*(N))

    local -a file_names
    file_names=(${file_paths:t})
    _wanted notebooks expl 'notebook' compadd -Q -- $file_names
  }

(( $+functions[_archived_notebooks] )) ||
  _archived_notebooks() {
    [[ -d "$NB_ROOT_DIR/$ARCHIVE_DIR_NAME" ]] || return 1

    local -a file_paths
    file_paths=("$NB_ROOT_DIR/$ARCHIVE_DIR_NAME"/*(N))

    local -a file_names
    file_names=(${file_paths:t})
    _wanted archived expl 'archived' compadd -Q -- $file_names
  }

_nb
